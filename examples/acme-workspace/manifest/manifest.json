{
  "manifest_version": 1,
  "organization": {
    "id": "acme",
    "name": "Acme Example"
  },
  "allowed_external_namespaces": [
    "mock"
  ],
  "umbrella": {
    "recommended_path": "~/acme"
  },
  "agent_guidance": {
    "paths": [
      "agent-guidance/acme.md"
    ]
  },
  "skills": [
    {
      "id": "acme:handbook",
      "install_slug": "acme-handbook",
      "path": "skills/acme-handbook",
      "capabilities": [
        "meetings",
        "support",
        "fleet",
        "decisions",
        "workspace"
      ],
      "requires": [
        "workspace:handbook",
        "service:docs-search"
      ]
    }
  ],
  "mounts": [
    {
      "id": "handbook",
      "kind": "handbook",
      "git_url": "https://github.com/example/acme-workspace-content.git",
      "mode": "default",
      "include_paths": [
        "meetings",
        "support",
        "fleet",
        "decisions",
        "projects",
        "policy",
        "people"
      ]
    }
  ],
  "tools": [
    {
      "id": "qmd",
      "mode": "optional",
      "purpose": "Higher quality local markdown search and retrieval",
      "install": {
        "commands": [
          "npm install -g @tobilu/qmd"
        ],
        "docs_url": "https://github.com/tobilu/qmd"
      }
    }
  ],
  "services": [
    {
      "id": "docs-search",
      "kind": "mcp",
      "purpose": "Search the public ACME fixture handbook",
      "describe_ref": "services/docs-search.server.json",
      "auth_ref": "env://ACME_DOCS_TOKEN",
      "grant": "read",
      "connection": {
        "type": "stdio",
        "command": "acme-docs-mcp",
        "args": [
          "--stdio"
        ],
        "env": {
          "ACME_DOCS_TOKEN": "${ACME_DOCS_TOKEN}"
        }
      }
    }
  ],
  "roles": [
    {
      "id": "operator",
      "purpose": "Default public fixture operator role",
      "guidance_paths": [
        "agent-guidance/acme.md"
      ],
      "mounts": [
        "handbook"
      ],
      "skills": [
        "acme:handbook"
      ],
      "tools": [
        "qmd"
      ],
      "services": [
        "docs-search"
      ]
    }
  ]
}
