{
  "manifest_version": 1,
  "organization": {
    "id": "acme",
    "name": "Acme Example"
  },
  "allowed_external_namespaces": [
    "mock"
  ],
  "umbrella": {
    "recommended_path": "~/acme"
  },
  "agent_guidance": {
    "paths": [
      "agent-guidance/acme.md"
    ]
  },
  "sync": {
    "publish_policy": "pr"
  },
  "skills": [
    {
      "id": "acme:handbook",
      "install_slug": "acme-handbook",
      "path": "skills/acme-handbook",
      "capabilities": [
        "meetings",
        "support",
        "fleet",
        "decisions",
        "workspace"
      ],
      "requires": [
        "workspace:handbook",
        "service:docs-search"
      ]
    }
  ],
  "mounts": [
    {
      "id": "handbook",
      "kind": "handbook",
      "git_url": "https://github.com/example/acme-workspace-content.git",
      "mode": "default",
      "include_paths": [
        "customers",
        "meetings",
        "support",
        "fleet",
        "decisions",
        "projects",
        "policy",
        "people"
      ]
    }
  ],
  "data_bindings": {
    "customers": {
      "surface": "mount:handbook",
      "guidance": [
        "agent-guidance/customers-domain.md"
      ]
    },
    "fleet": {
      "surface": "mount:handbook"
    },
    "meetings": {
      "surface": "mount:handbook"
    },
    "support": {
      "surface": "mount:handbook"
    }
  },
  "tools": [
    {
      "id": "qmd",
      "mode": "optional",
      "purpose": "Higher quality local markdown search and retrieval",
      "install": {
        "commands": [
          "npm install -g @tobilu/qmd"
        ],
        "docs_url": "https://github.com/tobilu/qmd"
      }
    }
  ],
  "services": [
    {
      "id": "docs-search",
      "kind": "mcp",
      "purpose": "Search the public ACME fixture handbook",
      "describe_ref": "services/docs-search.server.json",
      "auth_ref": "env://ACME_DOCS_TOKEN",
      "connection": {
        "type": "stdio",
        "command": "acme-docs-mcp",
        "args": [
          "--stdio"
        ],
        "env": {
          "ACME_DOCS_TOKEN": "${ACME_DOCS_TOKEN}"
        }
      }
    }
  ],
  "roles": [
    {
      "id": "operator",
      "purpose": "Default public fixture operator role",
      "guidance_paths": [
        "agent-guidance/acme.md"
      ],
      "mounts": [
        "handbook"
      ],
      "skills": [
        "acme:handbook"
      ],
      "tools": [
        "qmd"
      ],
      "services": [
        "docs-search"
      ]
    }
  ],
  "contract": [
    "Continue an existing relevant support record or create a new dated record when working on any fleet member."
  ],
  "governance": {
    "authorization": {
      "provider": "github",
      "manifest_repository": "example/acme-workspace-manifest",
      "admin_permission": "admin"
    },
    "access": {
      "positive_ttl": "15m",
      "check_interval": "5m",
      "revocation_confirmations": 2,
      "confirmation_interval": "15m",
      "quarantine_retention": "168h"
    },
    "policies": [
      {
        "id": "release-policy",
        "title": "Release policy",
        "mount": "handbook",
        "path": "policy/release.md",
        "version": "2026-01",
        "sha256": "sha256:d540eb677d59ed9c722592bcaf3b22d593f763c13a72854c7d4256d376716235",
        "acceptance": "required",
        "roles": [
          "operator"
        ]
      }
    ],
    "attestations": {
      "mount": "handbook",
      "path": "policy/attestations",
      "identity": "github"
    },
    "protections": [
      {
        "mount": "handbook",
        "paths": [
          "fleet",
          "support"
        ],
        "mode": "no-delete",
        "admin_override": true
      },
      {
        "mount": "handbook",
        "paths": [
          "policy/attestations"
        ],
        "mode": "append-only"
      }
    ]
  }
}
